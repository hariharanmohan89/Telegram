{
  "name": "telegram-secure-agent",
  "version": "1.0.0",
  "description": "Secure Telegram webhook bridge to OpenAI on Cloudflare Workers",
  "type": "module",
  "main": "src/worker.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck",
    "dev": "wrangler dev src/worker.ts --local",
    "deploy": "wrangler deploy src/worker.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "check": "npm run lint && npm run test && npm run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "openai": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@cloudflare/workers-types": "^4.20260222.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "wrangler": "^4.8.0"
  }
}
